# Environment variables — never commit secrets
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyc

# Jupyter checkpoints
.ipynb_checkpoints/

# Trained model & scaler (large binaries — regenerate via notebooks)
models/*.h5
models/*.pkl

# Raw & processed data (large files — downloaded/generated via scripts)
data/raw/
data/processed/

# Prediction output (generated at runtime)
dashboard/*.csv

# Virtual environment
venv/
.venv/
env/

# User profile data (runtime generated)
data/profiles.json

# Numpy sequence arrays (regenerate via notebooks)
data/processed/*.npy

# OS noise
.DS_Store
Thumbs.db
